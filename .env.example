# EnergyPlus MCP Server - Environment Variables
# Copy this file to .env and customize for your environment

# =============================================================================
# EnergyPlus Configuration
# =============================================================================

# Path to EnergyPlus installation directory
# Windows example: C:/EnergyPlusV25-2-0
# Linux example: /usr/local/EnergyPlus-25-2-0
# EPLUS_INSTALL_PATH=

# Path to EnergyPlus IDD file (optional - derived from EPLUS_INSTALL_PATH if not set)
# EPLUS_IDD_PATH=

# Path to EnergyPlus weather data directory (optional)
# EPLUS_WEATHER_PATH=

# Path to EnergyPlus example files directory (optional)
# EPLUS_EXAMPLE_FILES_PATH=

# Default weather file name or full path (optional)
# EPLUS_DEFAULT_WEATHER_FILE=USA_CA_San.Francisco.Intl.AP.724940_TMY3.epw

# =============================================================================
# MCP Server Configuration
# =============================================================================

# Workspace root directory (defaults to project directory)
# MCP_WORKSPACE_ROOT=

# Output directory for simulation results (defaults to {workspace}/outputs)
# MCP_OUTPUT_DIR=

# Temporary directory (defaults to system temp)
# MCP_TEMP_DIR=

# Sample files directory (defaults to {workspace}/sample_files)
# MCP_SAMPLE_FILES_PATH=

# =============================================================================
# Logging Configuration
# =============================================================================

# Enable debug mode (set to any value to enable)
# DEBUG=1

# =============================================================================
# Platform-Specific Notes
# =============================================================================

# WINDOWS:
# - Use forward slashes (/) or double backslashes (\\) in paths
# - EnergyPlus typically installs to C:/EnergyPlusV25-2-0
# - The server auto-detects common Windows installation locations
#
# Example Windows configuration:
# EPLUS_INSTALL_PATH=C:/EnergyPlusV25-2-0
# MCP_OUTPUT_DIR=C:/Users/YourName/energyplus-outputs

# LINUX/DOCKER:
# - Default paths are configured for the devcontainer setup
# - EnergyPlus expected at /app/software/EnergyPlusV25-2-0
#
# Example Linux configuration:
# EPLUS_INSTALL_PATH=/usr/local/EnergyPlus-25-2-0
# MCP_OUTPUT_DIR=/home/user/energyplus-outputs
